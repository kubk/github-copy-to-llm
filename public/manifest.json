{
  "manifest_version": 3,
  "name": "GitHub Markdown Copy Icon",
  "description": "Adds a copy button to GitHub repository READMEs and Gists.",
  "version": "0.0.0",
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*",
        "https://gist.github.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://github.com/*",
    "https://gist.github.com/*"
  ]
}
